        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <include file="db/changelog/db.changelog-master.xml" relativeToChangelogFile="false"/>

  <changeSet id="test-data-user" author="i.s.ivanov" runAlways="true" context="test">
    <loadData tableName="iam_user" file="db/data/user.csv" separator=";" usePreparedStatements="true">
      <column name="password_hash" type="text"/>
      <column name="status" type="other"/>
    </loadData>
  </changeSet>
</databaseChangeLog>
