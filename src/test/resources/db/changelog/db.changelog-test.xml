<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <include file="db/changelog/db.changelog-master.xml" relativeToChangelogFile="false"/>

  <changeSet id="test-data-user" author="i.s.ivanov" runAlways="true" context="test">
    <!-- pgjdbc sets the session time zone to the JVM default; the user.csv timestamps are TZ-naive
         (Liquibase only recognizes the offset-less yyyy-MM-dd'T'HH:mm:ss form). Pin the session to UTC
         so the naive seed instants are stored as UTC regardless of the host's time zone, matching the
         checked-in grid fixture in every environment (locally and in CI). -->
    <sql>SET TIME ZONE 'UTC';</sql>
    <loadUpdateData tableName="iam_user" file="db/data/user.csv" separator=";" primaryKey="id"
                    usePreparedStatements="true">
      <column name="password_hash" type="text"/>
      <column name="status" type="other"/>
      <column name="failed_login_attempts" type="numeric"/>
      <column name="locked_until" type="date"/>
    </loadUpdateData>
  </changeSet>
</databaseChangeLog>
