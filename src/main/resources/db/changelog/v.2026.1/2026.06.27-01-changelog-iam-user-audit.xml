<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <!-- Admin user grid read-model (Scenario 1.1): audit columns on iam_user.
       Added nullable, backfilled from registered_at / created_by, then made NOT NULL + FK. -->
  <changeSet id="2026-06-27-01-add-iam-user-audit-columns" author="i.s.ivanov">
    <addColumn tableName="iam_user">
      <column name="updated_at" type="timestamptz"/>
      <column name="updated_by" type="uuid"/>
    </addColumn>
  </changeSet>

  <changeSet id="2026-06-27-02-backfill-iam-user-audit" author="i.s.ivanov">
    <update tableName="iam_user">
      <column name="updated_at" valueComputed="registered_at"/>
      <column name="updated_by" valueComputed="created_by"/>
    </update>
  </changeSet>

  <changeSet id="2026-06-27-03-iam-user-audit-not-null-and-fk" author="i.s.ivanov">
    <addNotNullConstraint tableName="iam_user" columnName="updated_at" columnDataType="timestamptz"/>
    <addNotNullConstraint tableName="iam_user" columnName="updated_by" columnDataType="uuid"/>
    <addForeignKeyConstraint
            baseTableName="iam_user"
            baseColumnNames="updated_by"
            constraintName="fk_iam_user__updated_by__iam_user"
            referencedTableName="iam_user"
            referencedColumnNames="id"/>
  </changeSet>

</databaseChangeLog>
