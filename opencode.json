{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {file:~/.secrets/github-pat}"
      }
    },
    "jira": {
      "enabled": false
    },
    "render": {
      "type": "remote",
      "url": "https://mcp.render.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {file:~/.secrets/render-api-key}"
      }
    }
  }
}
