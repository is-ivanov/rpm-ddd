<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="rpm-ddd PMD rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

  <description>
    Project PMD ruleset: all 8 PMD Java categories enabled. Violations are burned down in batches
    (see Task 244) — rules owned by Spotless/Checkstyle/SpotBugs or contradicting project conventions
    are excluded/configured below; the pom.xml maxAllowedViolations ceiling ratchets down per batch.
  </description>

  <rule ref="category/java/bestpractices.xml">
    <!-- Wants assert*()/fail() in every test body. Off: the 3-tier DSL (tdd-rules.md) delegates
         verification to Statements assert* and custom AssertJ *Assert *instance* methods (plus BDD then(),
         catchThrowable) — PMD's assert detection recognizes only static method names, so it can't follow
         the delegation and flags honest tests (PasswordPolicyTest, UserTest, ...). extraAssertMethodNames
         covers static methods only, so it can't reach the Statements-delegated asserts either. The value
         (a test with no verification) is already guaranteed by the RED discipline (@ExpectedToFail +
         predicted failure per test). -->
    <exclude name="UnitTestShouldIncludeAssert"/>
    <!-- Caps a test at 1 assert. Off: direct conflict with the project rule "one action, assert all
         consequences (Level 1)" (tdd-rules.md) — an acceptance test triggers one action and asserts every
         observable consequence in multiple then blocks; all 12 hits are such L1 tests. No meaningful
         ceiling exists for "assert all consequences". -->
    <exclude name="UnitTestContainsTooManyAsserts"/>
    <!-- Wants log calls wrapped in an isXxxEnabled() guard. Off: the project logs only with SLF4J
         parameterized placeholders (log.info("... {}", arg)), where the guard is redundant — SLF4J defers
         message assembly past its own level check; the rule targets the old string-concatenation pattern
         (log.debug("x" + expensive())), which the project does not use. It is also the one rule that
         resolves logger types differently on Windows vs Linux, producing a non-deterministic count that
         broke the CI gate. -->
    <exclude name="GuardLogStatement"/>
    <!-- Wants a single-abstract-method interface annotated @FunctionalInterface. Off: the 3 hits are
         domain ports (UserSummaryQuery, EmailNotificationSender) and a Spring Data repository
         (SpringDataUserSummaryRepository) — role interfaces that happen to have one method today, not
         lambda targets. @FunctionalInterface would misdescribe their intent and freeze them at one method. -->
    <exclude name="ImplicitFunctionalInterface"/>
    <!-- Wants the literal first in String comparisons ("x".equals(y)) — Yoda notation. Off: it hurts
         readability, and its only benefit (NPE-safety when the left operand is null) is already owned by
         explicit null checks + NullAway static analysis. Also one of the rules whose count differs across
         Windows/Linux. -->
    <exclude name="LiteralsFirstInComparisons"/>
  </rule>
  <!-- "Test method without @Test" heuristic. Its testClassPattern default is the unanchored regex "Test",
       so it treats any class whose name merely *contains* "Test" as a test class — flagging the
       *TestExecutionListener infra. Anchor it to the project's test-suffix convention (AGENTS.md:
       *Test / *IntegrationTest — both end in Test) so only real *Test classes are checked. -->
  <rule ref="category/java/bestpractices.xml/UnitTestShouldUseTestAnnotation">
    <properties>
      <property name="testClassPattern" value="^(?:.*\.)?[^.]*Tests?$"/>
    </properties>
  </rule>


  <rule ref="category/java/codestyle.xml">
    <!-- Flag method args / locals that could be `final`. Off: no stack tool or project
         convention enforces `final` (no Checkstyle FinalParameters, Palantir does not add it). -->
    <exclude name="MethodArgumentCouldBeFinal"/>
    <exclude name="LocalVariableCouldBeFinal"/>
    <!-- Flag `var` declarations, wants explicit types. Off: the project adopted `var`
         (157 usages across 54 files); no tool in the stack forbids it. -->
    <exclude name="UseExplicitTypes"/>
    <!-- Caps variable-name length at 17 chars. Off: the threshold forces abbreviating descriptive
         collaborator/domain names (registrationPolicy, emailNotificationSender), contradicting the
         project's descriptive-naming convention; no other tool caps name length. -->
    <exclude name="LongVariable"/>
    <!-- Wants a `/* package */` comment on every package-private member to make default access
         explicit. Off: the access modifier is self-documenting; module boundaries are enforced by
         Spring Modulith + ArchUnit, and forced comments clash with the no-comments-unless-asked rule. -->
    <exclude name="CommentDefaultAccessModifier"/>
    <!-- Method-naming pattern (junit5TestPattern forbids `_`). Off: duplicates Checkstyle
         `MethodName`, which already owns both prod lowerCamelCase and the @Test-aware should_ pattern. -->
    <exclude name="MethodNamingConventions"/>
    <!-- Wants explicit `super()` in constructors. Off: Java auto-inserts no-arg super(); all 23 are test
         classes extending a base test; forcing redundant super() is noise. -->
    <exclude name="CallSuperInConstructor"/>
    <!-- Mandates a single return per method. Off: the project does not adopt single-return; guard clauses
         and early returns are idiomatic and improve readability. -->
    <exclude name="OnlyOneReturn"/>
    <!-- Wants at least one explicit constructor per class. Off: flags stateless/static-method classes and
         Spring @Configuration classes with only @Bean methods; default constructor suffices. -->
    <exclude name="AtLeastOneConstructor"/>
  </rule>
  <!-- Override: the default cap of 4 is too low for test DSLs that lean on static imports. -->
  <rule ref="category/java/codestyle.xml/TooManyStaticImports">
    <properties>
      <property name="maximumStaticImports" value="7"/>
    </properties>
  </rule>
  <!-- Allow a curated list of conventional short names rather than lowering the length threshold:
       `id` (entity/DTO identifier) and `bd` (Spring BeanDefinition). Any other short name still flags. -->
  <rule ref="category/java/codestyle.xml/ShortVariable">
    <properties>
      <property name="violationSuppressRegex" value="Avoid variables with short names like (id|bd)"/>
    </properties>
  </rule>
  <!-- Allow-list conventional short method names via XPath on the AST node (the message carries no
       name, so a regex can't target them): `on` (Spring @EventListener handler), `me` (/me endpoint),
       `id` (record-style accessor). Any other short method name still flags. -->
  <rule ref="category/java/codestyle.xml/ShortMethodName">
    <properties>
      <property name="violationSuppressXPath" value="./ancestor-or-self::MethodDeclaration[@Name = ('on', 'me', 'id')]"/>
    </properties>
  </rule>
  <!-- Allow the domain aggregate name `User` (the message carries the name, so a regex targets it —
       consistent with ShortVariable). Any other short class name still flags. -->
  <rule ref="category/java/codestyle.xml/ShortClassName">
    <properties>
      <property name="violationSuppressRegex" value="Avoid short class names like User"/>
    </properties>
  </rule>
  <!-- Keep the rule ON (it catches genuinely misnamed constants/fields — Checkstyle has no ConstantName).
       A `static final` field is treated as a constant (constantPattern), which rejects the universal
       SLF4J/Lombok logger idiom `private static final Logger log`. Allow `log` as an explicit alternative
       in the constant pattern (global, intentional); any other lowercase constant still flags. The ArchUnit
       camelCase @ArchTest rule fields in ArchitectureTest are handled by a class-level @SuppressWarnings. -->
  <rule ref="category/java/codestyle.xml/FieldNamingConventions">
    <properties>
      <property name="constantPattern" value="[A-Z][A-Z_0-9]*|log"/>
    </properties>
  </rule>


  <!-- Two orthogonal allow-lists, both keeping the rule active for real production code:
       - ignoredAnnotations: exempt @Test/@ParameterizedTest methods whose names start with an HTTP
         verb ("getRequest..."), a false positive vs the get*->void getter check;
       - violationSuppressXPath: exempt methods inside *Assert classes — custom AssertJ asserts name
         has* methods that return the assert type for chaining (idiomatic), not a boolean.
       A has*-returns-non-boolean method in a non-Assert prod class, or a real get*->void getter, still flags. -->
  <rule ref="category/java/codestyle.xml/LinguisticNaming">
    <properties>
      <property name="ignoredAnnotations" value="org.junit.jupiter.api.Test,org.junit.jupiter.params.ParameterizedTest"/>
      <property name="violationSuppressXPath" value="./ancestor::ClassDeclaration[ends-with(@SimpleName, 'Assert')]"/>
    </properties>
  </rule>


  <!-- Keep the rule ON (it catches anemic domain objects — a core DDD concern), but suppress it on
       *View classes: by project convention a `{Name}View` is a read-only persistence projection
       (@Subselect / read model) whose whole purpose is to be a dumb typed row carrier the ORM populates
       and the adapter maps to a DTO — behavior lives in the write aggregate. Same suffix-allow-list
       approach as LinguisticNaming/*Assert. A data-only class NOT named *View still flags. -->
  <rule ref="category/java/design.xml/DataClass">
    <properties>
      <property name="violationSuppressXPath" value="./ancestor-or-self::ClassDeclaration[ends-with(@SimpleName, 'View')]"/>
    </properties>
  </rule>
  <rule ref="category/java/design.xml">
    <!-- "Talk only to friends" — flags a.b().c() chains. Off: 9/17 are enum-constant accesses
         (UserStatus.PENDING); the rest are unavoidable fluent/builder/stream API navigations and library
         type traversal (jjwt, HTTP, Jakarta). Zero genuine object-graph navigation violations. -->
    <exclude name="LawOfDemeter"/>
    <!-- Caps method count per class (default 10). Off: the project already enforces a hard 200-line file
         limit (AGENTS.md / coding-rules.md, verified with wc -l) on every file including production — that
         is the adopted guard against class bloat, and this pure method-count heuristic duplicates it. The 4
         hits are all legitimate method-rich patterns the count conflicts with: read-projection accessors
         (UserSummaryView — record-style firstName() isn't recognized as a getter), the 3-tier test DSL
         (UserStatements — one method per scenario step), a fluent assertion helper (AssertionResponse — 25
         methods in 197 lines, already at the line cap), and transport overloads (AuthApi — login×5/activate×2
         counted separately). A real god-class cannot exist under the 200-line cap. -->
    <exclude name="TooManyMethods"/>
    <!-- Measures coupling between a hand-maintained list of packages, which requires a mandatory
         `packages` property. Off: unconfigured it is dead weight — PMD logs "Removed misconfigured rule:
         LoosePackageCoupling cause: No packages or classes specified" on every build and emits a
         <configerror> (never a violation, so it never counted). Configuring it would duplicate module
         boundaries already owned and CI-enforced by Spring Modulith + ArchUnit. Excluding it silences the
         per-build warning. -->
    <exclude name="LoosePackageCoupling"/>
  </rule>
  <!-- Keep the rule ON (we agree unchecked exceptions don't belong in signatures we own), but suppress it
       on @Override methods — there the throws clause is dictated by the framework interface we implement,
       not by us (Spring UserDetailsService.loadUserByUsername throws UsernameNotFoundException, Jackson
       deserialize throws JacksonException, Spring BeanDefinitionRegistryPostProcessor throws BeansException).
       A non-@Override method that declares an unchecked exception still flags. -->
  <rule ref="category/java/design.xml/AvoidUncheckedExceptionsInSignatures">
    <properties>
      <property name="violationSuppressXPath" value="./ancestor::MethodDeclaration[ModifierList/Annotation[@SimpleName='Override']]"/>
    </properties>
  </rule>
  <!-- Keep the rule ON (final-by-default for private-constructor classes is useful), but suppress it on
       @Table-annotated classes: JPA/Hibernate entities cannot be final (proxying/weaving). Genuine test
       helpers flagged by this rule are fixed in code with `final`, not suppressed. -->
  <rule ref="category/java/design.xml/ClassWithOnlyPrivateConstructorsShouldBeFinal">
    <properties>
      <property name="violationSuppressXPath" value="./ancestor-or-self::ClassDeclaration[ModifierList/Annotation[@SimpleName='Table']]"/>
    </properties>
  </rule>


  <rule ref="category/java/documentation.xml">
    <!-- Configured in Checkstyle -->
    <exclude name="CommentRequired"/>
    <!-- Caps comment line length (80) and comment block lines (6). Off: line length is owned by
         Checkstyle LineLength=120; the 6-line cap conflicts with preserving Javadoc/comments. -->
    <exclude name="CommentSize"/>
  </rule>


  <rule ref="category/java/errorprone.xml">
    <!-- Flags fields matching method names. Off: every record component (email, code, id, ...) has an
         auto-generated accessor with the same name — inherent false positive for record-heavy code. -->
    <exclude name="AvoidFieldNameMatchingMethodName"/>
    <!-- Prefers Thread.currentThread().getContextClassLoader() over X.class.getClassLoader(). Off: the
         rule's premise is J2EE app servers with a multi-classloader hierarchy. In a Spring Boot fat-jar
         (single app classloader) both hits load a resource co-packaged with the loading class
         (ActivationEmailRenderer + its email template; TestResources + test resources) — the class's own
         classloader is the correct, deterministic choice, and TCCL (mutable per thread) would be a regression. -->
    <exclude name="UseProperClassLoader"/>
  </rule>
  <!-- "Looks like a test class but has no test cases" heuristic. Its default pattern flags names that
       *start or end* with Test/Tests/TestCase, catching Test-prefixed infrastructure that is not a test
       (TestRpmDddApplication, TestcontainersConfiguration, TestResources). Anchor
       it to the project's test-suffix convention (AGENTS.md: *Test / *IntegrationTest) so only real *Test
       classes are checked; the Test-prefixed infra is exempt. -->
  <!-- Tightened: a String literal repeated even twice should be a named constant (default threshold is 4).
       skipAnnotations avoids flagging repeated annotation values (@SuppressWarnings("unchecked"),
       @DisplayName/@ParameterizedTest name templates) which cannot sensibly be constants. -->
  <rule ref="category/java/errorprone.xml/AvoidDuplicateLiterals">
    <properties>
      <property name="maxDuplicateLiterals" value="2"/>
      <property name="skipAnnotations" value="true"/>
    </properties>
  </rule>
  <rule ref="category/java/errorprone.xml/TestClassWithoutTestCases">
    <properties>
      <property name="testClassPattern" value="^(?:.*\.)?[^.]*Tests?$"/>
    </properties>
  </rule>


  <rule ref="category/java/multithreading.xml"/>


  <rule ref="category/java/performance.xml"/>


  <rule ref="category/java/security.xml"/>

</ruleset>
