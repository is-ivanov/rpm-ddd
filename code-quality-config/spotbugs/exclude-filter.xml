<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclude filter for triaged false positives.

  Wired into the build via the spotbugs-maven-plugin <excludeFilterFile> in pom.xml.
  An empty filter (no <Match> elements) excludes nothing — this is the clean
  baseline. Each exclusion added during triage MUST be documented with a comment
  explaining why the finding is a false positive (or an accepted, justified
  deviation), mirroring the documented-deviation convention used for Checkstyle.

  Filter syntax: https://spotbugs.readthedocs.io/en/stable/filter.html
-->
<FindBugsFilter>

  <!--
    RV_RETURN_VALUE_IGNORED_NO_SIDE_EFFECT — false positive on Java record canonical
    constructors and the Spring Data AbstractAggregateRoot super() call. SpotBugs
    misreads the INVOKESPECIAL to <init> as an ignored `new` result. These are
    validating value-object records (EmailAddress, Login, Password, PersonName,
    UserId) and the User aggregate root, not ignored return values. Scoped to the
    domain packages where these records/entities live.
  -->
  <Match>
    <Bug pattern="RV_RETURN_VALUE_IGNORED_NO_SIDE_EFFECT"/>
    <Class name="~by\.iivanov\.rpm\..*\.domain\..*"/>
  </Match>

  <!--
    CT_CONSTRUCTOR_THROW — not applicable to Spring container-managed singleton beans.
    Application services are instantiated once at startup from trusted configuration:
    there is no attacker-controlled construction path, and they are commonly AOP-proxied
    (@Transactional/@Async/@Cacheable), so they cannot be made final to silence this.
    A throwing constructor here fails context startup fast (config validation) rather
    than leaking a partially constructed object via a finalizer attack. SpotBugs has no
    annotation-based matcher, so we scope this by the application-service NAMING
    convention (`*Service` in an `.application.` package) — narrow enough to leave
    command/DTO records and any other application-layer type subject to the detector.
    (Domain services use `final` instead — see JwtActivationTokenGenerator; value
    objects and command records are records and therefore implicitly final.)
  -->
  <Match>
    <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    <Class name="~.*\.application\..*Service"/>
  </Match>

  <!--
    NM_CLASS_NAMING_CONVENTION — the jMolecules byte-buddy plugin generates synthetic
    helper classes named `<Type>$jMolecules$<hash>` (e.g. UserAssociationConverter).
    The lowercase `jMolecules` infix is generated bytecode we do not control.
  -->
  <Match>
    <Bug pattern="NM_CLASS_NAMING_CONVENTION"/>
    <Class name="~.*\$jMolecules\$.*"/>
  </Match>

  <!--
    BC_UNCONFIRMED_CAST — false positive on error-handling-spring-boot-starter
    ApiExceptionHandler implementations. The interface contract guarantees that
    handle(Throwable) is only ever called after canHandle(Throwable) returned true
    (documented on ApiExceptionHandler), so the downcast inside handle() is safe — but
    SpotBugs cannot see that cross-method guarantee. The starter's own handlers cast the
    same way (e.g. TypeMismatchApiExceptionHandler → TypeMismatchException). The
    code-level alternative (pattern-match + throw on the impossible branch) only trades
    this finding for a permanently-uncovered defensive branch. Scoped by the
    `*ExceptionHandler` naming convention in the web adapter package.
  -->
  <Match>
    <Bug pattern="BC_UNCONFIRMED_CAST"/>
    <Class name="~.*\.infrastructure\.web\..*ExceptionHandler"/>
  </Match>

</FindBugsFilter>
