    "@vue/test-utils": "^2.4.6",
    "allure-playwright": "^3.9.0",
    "allure-vitest": "^3.9.0",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0"
