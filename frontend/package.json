{
  "name": "rpm-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:fullstack": "playwright test --project=fullstack",
    "lint:oxlint": "oxlint --max-warnings=0",
    "lint": "npm run lint:oxlint && eslint . && prettier --check . && npm run type-check",
    "lint:fix": "oxlint --fix && eslint . --fix && prettier --write .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.6",
    "allure-js-commons": "^3.9.0",
    "allure-playwright": "^3.9.0",
    "allure-vitest": "^3.9.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.69.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^26.0.0",
    "msw": "^2.14.6",
    "oxlint": "^1.69.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.2.0"
  }
}
