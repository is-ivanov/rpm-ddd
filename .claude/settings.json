{
  "enabledPlugins": {
    "jdtls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "frontend-design@claude-code-plugins": true
  },
  "plansDirectory": "./ProductSpecification/plans",
  "env": {
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "permissions": {
    "allow": [
      "Bash(./mvnw *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(egrep *)",
      "Bash(fd *)",
      "Bash(fdfind *)",
      "Bash(fgrep *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr view:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git remote:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jar tf *)",
      "Bash(mvn *)",
      "Bash(npm -v)",
      "Bash(npm ci *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx *)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(rg *)",
      "Bash(sort *)",
      "Bash(tail *)",
      "Bash(tree *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "PowerShell(./mvnw *)",
      "PowerShell(.\\\\mvnw *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Get-Command *)",
      "PowerShell(Get-Content *)",
      "PowerShell(Measure-Object *)",
      "PowerShell(Select-Object *)",
      "PowerShell(Select-String *)"
    ],
    "deny": [],
    "ask": []
  }
}
