# Agent progress log — ephemeral runtime milestones, cleared at the start of
# each /continue work unit. Useful only for live `tail -f` within a session;
# cross-session state lives in progress.md, so it is not tracked.
infrastructure/agent-progress.log
# Malformed absolute-path variant accidentally created on Windows
D*infrastructureagent-progress.log

# Playwright MCP browser-session artifacts (snapshots, console/network logs,
# screenshots) created during ad-hoc QA. Throwaway — never tracked.
.playwright-mcp/

# Claude Code git worktrees (agent isolation)
.claude/worktrees/
